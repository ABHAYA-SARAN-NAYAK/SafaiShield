# Backend API (your Railway/Render URL)
VITE_API_URL=http://localhost:8000

# Supabase (public anon key — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenWeatherMap (free tier, safe to expose)
VITE_OPENWEATHER_KEY=your-weather-key

# Telegram Bot username (for deep links — no token!)
VITE_TELEGRAM_BOT_USERNAME=SafaiShieldBot

# App config
VITE_APP_NAME=SafaiShield
VITE_DEFAULT_LANGUAGE=en
